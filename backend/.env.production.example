# Copy this file to .env (outside of VCS) and set real secrets before deploying
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=school_management
PORT=5000
JWT_SECRET=change_this_to_a_secure_secret
# Comma-separated list of allowed origins for CORS (e.g. https://example.com)
# Replace <VERCEL_URL> with your frontend URL (example: https://school-management-systems-ebon.vercel.app)
# Include localhost for local development if needed.
# Example value for Render ENV: http://localhost:5174,https://school-management-systems-ebon.vercel.app
CORS_ORIGIN=http://localhost:5174,https://<VERCEL_URL>
